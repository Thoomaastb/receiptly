# --- GHCR-Package-Bezug ---
# Muss exakt eurem GitHub-Namespace entsprechen — sonst zieht docker compose pull
# ein "manifest unknown", weil es beim falschen Namespace sucht.
GITHUB_REPOSITORY_OWNER=thoomaastb

# --- Datenbank ---
POSTGRES_USER=receiptly
POSTGRES_PASSWORD=change-me
POSTGRES_DB=receiptly
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://receiptly:change-me@db:5432/receiptly

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Sessions ---
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_COOKIE_NAME=receiptly_session
SESSION_MAX_AGE_SECONDS=1209600

# Fernet-Key für verschlüsselte Settings (z.B. AI-Provider-API-Keys). Erzeugen mit:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- KI (optional, Default = lokal) ---
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
# EXTERNAL_AI_API_KEY=   # nur bei explizitem Opt-in, siehe Security & Privacy

# --- E-Mail (Passwort-Reset) ---
# Ohne SMTP_HOST bleibt der Versand aus (Fehler landet nur im Backend-Log, die
# Reset-Anfrage antwortet trotzdem immer erfolgreich — verhindert User-Enumeration).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@receiptly.example
# starttls (Port 587, TLS-Upgrade nach Klartext-Connect) oder ssl (Port 465, TLS
# von Anfang an) — nur eine der beiden Varianten pro Provider, nicht raten sondern
# beim Mail-Hoster nachsehen welche verlangt wird.
SMTP_ENCRYPTION=starttls

# Basis-URL des Frontends, aus der der Reset-Link in der E-Mail gebaut wird
# (z.B. https://receiptly.example.com/reset-password?token=...)
PUBLIC_APP_URL=http://localhost:5173
