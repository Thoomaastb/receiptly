# --- GHCR-Package-Bezug ---
# Muss exakt eurem GitHub-Namespace entsprechen — sonst zieht docker compose pull
# ein "manifest unknown", weil es beim falschen Namespace sucht.
GITHUB_REPOSITORY_OWNER=thoomaastb

# --- Datenbank ---
POSTGRES_USER=receiptly
POSTGRES_PASSWORD=change-me
POSTGRES_DB=receiptly
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://receiptly:change-me@db:5432/receiptly

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Sessions ---
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_COOKIE_NAME=receiptly_session
SESSION_MAX_AGE_SECONDS=1209600

# Fernet-Key für verschlüsselte Settings (z.B. AI-Provider-API-Keys). Erzeugen mit:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173

# --- KI-Struktur-Extraktion (optional, alles leer = nur lokale Texterfassung ohne
# KI-Strukturierung) — 3-stufige Prioritätskette, ausgewertet in
# app/services/ai_provider_resolution.py:
#   1. OLLAMA_HOST gesetzt        -> Ollama wird server-weit erzwungen (OLLAMA_MODEL als
#                                     Modell-Override), Haushalts-Settings-UI wird read-only.
#   2. sonst AI_HOST gesetzt      -> dieser externe Provider (openai|anthropic|google) wird
#                                     server-weit erzwungen (AI_KEY als zugehöriger Schlüssel),
#                                     Haushalts-Settings-UI wird read-only.
#   3. sonst                      -> pro Haushalt über die Settings-UI konfigurierbar
#                                     (OpenAI/Anthropic/Google mit eigenem Key, oder
#                                     Ollama/Lokal mit eigenem Host+Modell, kein Key).
#   4. nichts davon konfiguriert  -> nur lokale Texterfassung (OCR wie bisher), kein
#                                     KI-Aufruf.
# Beachte: der OCR-Rohtext wird vor jedem KI-Versand (auch an lokales Ollama) durch
# app/services/pii_redaction.py von IBAN-/Kartennummern-artigen Mustern bereinigt.
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL=llama3.1
# AI_HOST=openai
# AI_KEY=   # nur bei explizitem Opt-in, siehe Security & Privacy
AI_EXTRACTION_TIMEOUT_SECONDS=25.0
AI_EXTRACTION_MAX_OCR_CHARS=4000

# --- E-Mail (Passwort-Reset) ---
# Ohne SMTP_HOST bleibt der Versand aus (Fehler landet nur im Backend-Log, die
# Reset-Anfrage antwortet trotzdem immer erfolgreich — verhindert User-Enumeration).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=noreply@receiptly.example
# starttls (Port 587, TLS-Upgrade nach Klartext-Connect) oder ssl (Port 465, TLS
# von Anfang an) — nur eine der beiden Varianten pro Provider, nicht raten sondern
# beim Mail-Hoster nachsehen welche verlangt wird.
SMTP_ENCRYPTION=starttls

# Basis-URL des Frontends, aus der der Reset-Link in der E-Mail gebaut wird
# (z.B. https://receiptly.example.com/reset-password?token=...)
PUBLIC_APP_URL=http://localhost:5173
